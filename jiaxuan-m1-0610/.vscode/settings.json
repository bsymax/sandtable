{
  "extensions": {
    "recommendations": [
      "ms-python.python",
      "ms-python.vscode-pylance"
    ]
  },
  "settings": {
    "python.defaultInterpreterPath": "python3",
    "[python]": { "editor.tabSize": 4 },
    "[html]": { "editor.tabSize": 2 },
    "files.exclude": {
      "**/__pycache__": true,
      "**/*.pyc": true
    }
  }
}
