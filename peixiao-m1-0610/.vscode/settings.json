{
  "extensions": {
    "recommendations": [
      "ms-python.python",
      "ms-python.vscode-pylance",
      "ritwickdey.liveserver",
      "adpyke.vscode-sql-formatter"
    ]
  },
  "settings": {
    "python.defaultInterpreterPath": "python3",
    "python.analysis.typeCheckingMode": "basic",
    "[python]": {
      "editor.formatOnSave": true,
      "editor.tabSize": 4
    },
    "[html]": {
      "editor.tabSize": 2
    },
    "[sql]": {
      "editor.tabSize": 2
    },
    "files.exclude": {
      "**/__pycache__": true,
      "**/*.pyc": true
    }
  }
}
