# 复制本文件为 .env 并填入你本机的数据库密码
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=改成你的密码
DB_NAME=brand_sandtable
DB_CHARSET=utf8mb4

SERVER_HOST=0.0.0.0
SERVER_PORT=8000

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5510

# M4-C 数仓主频（BI 首接 monthly）
DW_METRICS_PERIOD_TYPE=monthly

# M4-B LLM 配额（0 = 不限制）
LLM_DAILY_CAP=2000
LLM_USER_DAILY_CAP=200
